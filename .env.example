# =============================================================================
# TrackLink Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tracklink
POSTGRES_USER=tracklink
POSTGRES_PASSWORD=your_secure_password_here

# Full database URL (constructed from above, or override directly)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Backend API Server
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_DEBUG=false

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=5

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_MAP_PROVIDER=openstreetmap

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443
SERVER_NAME=localhost

# -----------------------------------------------------------------------------
# Tracking Defaults
# -----------------------------------------------------------------------------
DEFAULT_UPDATE_INTERVAL_SECONDS=10
LOCATION_DEDUP_DISTANCE_METERS=5
DEVICE_OFFLINE_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Admin Account (created on first run)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@tracklink.local
ADMIN_PASSWORD=change_this_password
